<!-- ============================================================
   জাভাস্ক্রিপ্ট (হুবহু ফ্লিপকার্ট)
   ============================================================ -->
{% block extra_js %}
<script>
    // ============================================================
    // ভিউ টগল (গ্রিড/লিস্ট)
    // ============================================================
    function setView(view) {
        const buttons = document.querySelectorAll('.d-flex.gap-2 .btn');
        const grid = document.getElementById('product-grid');
        const items = document.querySelectorAll('.product-item');
        
        // বাটন আপডেট
        buttons.forEach(btn => btn.classList.remove('active'));
        if (view === 'grid') {
            buttons[0].classList.add('active');
            // গ্রিড ভিউ
            items.forEach(item => {
                item.className = 'col-6 col-md-4 col-xl-3 product-item';
            });
            localStorage.setItem('productView', 'grid');
        } else {
            buttons[1].classList.add('active');
            // লিস্ট ভিউ
            items.forEach(item => {
                item.className = 'col-12 product-item';
                // লিস্ট ভিউতে কার্ড স্টাইল পরিবর্তন
                const card = item.querySelector('.fk-product-card');
                card.style.display = 'flex';
                card.style.flexDirection = 'row';
                card.style.alignItems = 'center';
                card.style.padding = '12px';
            });
            localStorage.setItem('productView', 'list');
        }
    }
    
    // লোড হলে পূর্ববর্তী ভিউ সেট করা
    document.addEventListener('DOMContentLoaded', function() {
        const savedView = localStorage.getItem('productView') || 'grid';
        setView(savedView);
    });
    
    // ============================================================
    // এড টু কার্ট AJAX
    // ============================================================
    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const form = this.closest('form');
            const originalText = this.innerHTML;
            
            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            this.disabled = true;
            
            fetch(form.action, {
                method: 'POST',
                headers: {
                    'X-CSRFToken': '{{ csrf_token }}',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: new FormData(form)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ Added to cart!', 'success');
                    updateCartCount(data.cart_count);
                } else {
                    showToast(data.message || '❌ Failed to add', 'error');
                }
            })
            .catch(() => {
                showToast('❌ Something went wrong', 'error');
            })
            .finally(() => {
                this.innerHTML = originalText;
                this.disabled = false;
            });
        });
    });
</script>
{% endblock %}
