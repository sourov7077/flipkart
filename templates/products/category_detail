{% extends 'base.html' %}
{% load static %}

{% block title %}{{ category.name }} - Flipkart{% endblock %}

{% block content %}
<!-- ============================================================
   ব্রেডক্রাম্ব (ফ্লিপকার্ট স্টাইল)
   ============================================================ -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb" style="background: transparent; padding: 0; margin: 0; font-size: 13px;">
        <li class="breadcrumb-item">
            <a href="{% url 'home:home' %}" class="text-decoration-none text-muted">
                <i class="fas fa-home me-1"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{% url 'products:product_list' %}" class="text-decoration-none text-muted">
                Products
            </a>
        </li>
        <li class="breadcrumb-item active fw-600" style="color: var(--text-dark);">
            {{ category.name }}
        </li>
    </ol>
</nav>

<div class="row g-3">
    <!-- ============================================================
    ফিল্টার সাইডবার (ফ্লিপকার্ট স্টাইল)
    ============================================================ -->
    <div class="col-lg-3">
        <div class="fk-card sticky-top" style="top: 100px;">
            <div class="fk-card-header" style="font-size: 15px; border-bottom: 1px solid var(--border-gray); padding-bottom: 12px;">
                <i class="fas fa-sliders-h me-2 text-blue"></i> Filters
            </div>
            
            <form method="GET" id="filter-form">
                <!-- ক্যাটাগরি -->
                <div class="mb-3">
                    <label class="fw-600 mb-2" style="font-size: 13px; color: var(--text-dark);">
                        <i class="fas fa-tag me-1"></i> Category
                    </label>
                    <p class="mb-0 fw-600 text-blue" style="font-size: 14px;">
                        <i class="fas fa-check-circle me-1" style="font-size: 12px;"></i>
                        {{ category.name }}
                    </p>
                </div>
                
                <!-- প্রাইস রেঞ্জ -->
                <div class="mb-3">
                    <label class="fw-600 mb-2" style="font-size: 13px; color: var(--text-dark);">
                        <i class="fas fa-money-bill-wave me-1"></i> Price Range
                    </label>
                    <div class="row g-1">
                        <div class="col-6">
                            <input type="number" name="min_price" class="form-control form-control-sm rounded-0" 
                                   placeholder="Min" value="{{ request.GET.min_price }}" style="font-size: 13px;">
                        </div>
                        <div class="col-6">
                            <input type="number" name="max_price" class="form-control form-control-sm rounded-0" 
                                   placeholder="Max" value="{{ request.GET.max_price }}" style="font-size: 13px;">
                        </div>
                    </div>
                </div>
                
                <!-- সর্ট বাই -->
                <div class="mb-3">
                    <label class="fw-600 mb-2" style="font-size: 13px; color: var(--text-dark);">
                        <i class="fas fa-sort me-1"></i> Sort By
                    </label>
                    <select name="sort_by" class="form-select form-select-sm rounded-0" onchange="this.form.submit()">
                        <option value="newest" {% if request.GET.sort_by == 'newest' %}selected{% endif %}>Newest First</option>
                        <option value="price_low" {% if request.GET.sort_by == 'price_low' %}selected{% endif %}>Price: Low to High</option>
                        <option value="price_high" {% if request.GET.sort_by == 'price_high' %}selected{% endif %}>Price: High to Low</option>
                        <option value="name" {% if request.GET.sort_by == 'name' %}selected{% endif %}>Name A-Z</option>
                    </select>
                </div>
                
                <!-- অ্যাকশন বাটন -->
                <div class="d-grid gap-2">
                    <button type="submit" class="btn fk-btn-primary btn-sm w-100 rounded-0">
                        <i class="fas fa-search me-1"></i> Apply Filters
                    </button>
                    <a href="{% url 'products:category_detail' category.slug %}" class="btn fk-btn-outline btn-sm w-100 rounded-0">
                        <i class="fas fa-times me-1"></i> Clear All
                    </a>
                </div>
            </form>
        </div>
        
        <!-- সাব-ক্যাটাগরি (যদি থাকে) -->
        {% if subcategories %}
        <div class="fk-card mt-3">
            <div class="fk-card-header" style="font-size: 14px; padding-bottom: 10px;">
                <i class="fas fa-list-ul me-2 text-blue"></i> Sub-Categories
            </div>
            {% for sub in subcategories %}
            <a href="{% url 'products:category_detail' sub.slug %}" 
               class="d-block text-decoration-none px-2 py-2 hover-bg-light transition"
               style="color: var(--text-dark); font-size: 13px; border-bottom: 1px solid var(--border-gray);">
                <i class="fas fa-chevron-right me-2" style="font-size: 10px; color: var(--text-light);"></i>
                {{ sub.name }}
                <span class="badge bg-light text-dark rounded-0 float-end">{{ sub.products.count }}</span>
            </a>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    
    <!-- ============================================================
    প্রোডাক্ট গ্রিড (ফ্লিপকার্ট স্টাইল)
    ============================================================ -->
    <div class="col-lg-9">
        <!-- ক্যাটাগরি হেডার -->
        <div class="fk-card mb-3" style="background: linear-gradient(135deg, #f0f7ff, #ffffff); border-left: 4px solid var(--primary-blue);">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h4 class="fw-700 mb-0" style="font-size: 20px;">
                        <i class="fas fa-{{ category.icon|default:'shopping-bag' }} text-blue me-2"></i>
                        {{ category.name }}
                    </h4>
                    {% if category.description %}
                    <p class="text-muted mb-0" style="font-size: 14px; margin-top: 4px;">
                        {{ category.description }}
                    </p>
                    {% endif %}
                </div>
                <div>
                    <span class="badge bg-primary rounded-0 px-3 py-2" style="font-size: 14px;">
                        <i class="fas fa-box me-1"></i>
                        {{ products|length }} Products
                    </span>
                </div>
            </div>
        </div>
        
        <!-- প্রোডাক্ট কাউন্ট + ভিউ -->
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
            <p class="text-muted mb-0" style="font-size: 14px;">
                Showing <span class="fw-600">{{ products|length }}</span> products
                {% if request.GET.q %}
                for "<span class="fw-600 text-blue">{{ request.GET.q }}</span>"
                {% endif %}
            </p>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm rounded-0 active" style="font-size: 12px; padding: 4px 10px;" onclick="setView('grid')">
                    <i class="fas fa-th"></i>
                </button>
                <button class="btn btn-outline-secondary btn-sm rounded-0" style="font-size: 12px; padding: 4px 10px;" onclick="setView('list')">
                    <i class="fas fa-list"></i>
                </button>
            </div>
        </div>
        
        <!-- প্রোডাক্ট গ্রিড -->
        {% if products %}
        <div class="row g-3" id="product-grid">
            {% for product in products %}
            <div class="col-6 col-md-4 col-xl-3 product-item">
                <div class="fk-product-card">
                    <div class="product-image" style="height: 170px;">
                        {% if product.get_image_url %}
                        <img src="{{ product.get_image_url }}" alt="{{ product.name }}" loading="lazy">
                        {% else %}
                        <i class="fas fa-image fa-3x text-muted"></i>
                        {% endif %}
                        {% if product.discount_percentage > 0 %}
                        <span class="fk-discount-tag">{{ product.discount_percentage }}% OFF</span>
                        {% endif %}
                        {% if not product.in_stock %}
                        <span class="badge bg-danger position-absolute bottom-0 start-50 translate-middle-x mb-2 rounded-0" style="font-size: 11px; padding: 4px 12px;">
                            Out of Stock
                        </span>
                        {% endif %}
                    </div>
                    
                    <div class="product-body">
                        <div class="product-title">
                            <a href="{% url 'products:product_detail' product.id %}" class="text-dark text-decoration-none">
                                {{ product.name|truncatechars:30 }}
                            </a>
                        </div>
                        
                        <div class="product-price">
                            ৳{{ product.price }}
                            {% if product.old_price %}
                            <span class="original">৳{{ product.old_price }}</span>
                            {% endif %}
                        </div>
                        
                        {% if product.discount_percentage > 0 %}
                        <div class="product-price">
                            <span class="discount">{{ product.discount_percentage }}% off</span>
                        </div>
                        {% endif %}
                        
                        <div class="product-rating">
                            <span class="rating-badge">
                                4.2 <i class="fas fa-star" style="font-size: 10px;"></i>
                            </span>
                            <span>({{ product.reviews.all|length }})</span>
                        </div>
                    </div>
                    
                    <div class="product-footer">
                        <a href="{% url 'products:product_detail' product.id %}" class="btn fk-btn-outline btn-sm flex-fill rounded-0" style="font-size: 12px;">
                            <i class="fas fa-eye"></i> View
                        </a>
                        {% if product.in_stock %}
                        <form action="{% url 'cart:cart_add' product.id %}" method="post" class="flex-fill">
                            {% csrf_token %}
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" class="btn fk-btn-primary btn-sm w-100 rounded-0 add-to-cart-btn" style="font-size: 12px;">
                                <i class="fas fa-cart-plus"></i>
                            </button>
                        </form>
                        {% endif %}
                        {% include 'includes/wishlist_button.html' with product=product in_wishlist=product.in_wishlist size='sm' %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <!-- খালি অবস্থা -->
        <div class="fk-card text-center py-5">
            <i class="fas fa-box-open" style="font-size: 64px; color: var(--text-light);"></i>
            <h5 class="fw-700 mt-3" style="font-size: 18px;">No Products Found</h5>
            <p class="text-muted" style="font-size: 14px;">
                There are no products in "<strong>{{ category.name }}</strong>" category yet.
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="{% url 'products:product_list' %}" class="btn fk-btn-primary rounded-0 px-4">
                    <i class="fas fa-store me-1"></i> Browse All
                </a>
                {% if user.is_staff %}
                <a href="/admin/products/product/add/" class="btn btn-outline-danger rounded-0 px-4">
                    <i class="fas fa-plus-circle me-1"></i> Add Product
                </a>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>
</div>

