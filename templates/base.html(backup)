    <!-- ============================================================
    টোস্ট কন্টেইনার
    ============================================================ -->
    <div id="fk-toast-container"></div>

    <!-- ============================================================
    SCRIPTS
    ============================================================ -->
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    {% load static %}
    <script src="{% static 'js/main.js' %}"></script>
    
    <script>
        // ============================================================
        // ১. লোডিং ওভারলে - পেজ লোড হলে লুকান
        // ============================================================
        document.addEventListener('DOMContentLoaded', function() {
            const loader = document.getElementById('fkLoader');
            if (loader) {
                loader.classList.add('hidden');
                setTimeout(function() {
                    loader.style.display = 'none';
                }, 500);
            }
        });

        // ============================================================
        // ২. ✅ লিংক ক্লিক - Home পেজের ক্যাটাগরি ট্যাবে লোডিং দেখাবে না
        //    (data-no-loader থাকলে লোডিং বন্ধ)
        // ============================================================
        document.addEventListener('click', function(e) {
            const link = e.target.closest('a');
            if (link && link.href && !link.href.startsWith('javascript:') && !link.target) {
                
                // ✅ যদি link এ data-no-loader থাকে -> লোডিং দেখাবে না
                if (link.hasAttribute('data-no-loader')) {
                    console.log('🔵 No loader for:', link.href);
                    return;
                }
                
                // ✅ অভ্যন্তরীণ লিংকের জন্য লোডিং দেখাবে
                if (link.href.startsWith(window.location.origin)) {
                    console.log('🔄 Loading for:', link.href);
                    const loader = document.getElementById('fkLoader');
                    if (loader) {
                        loader.style.display = 'flex';
                        loader.classList.remove('hidden');
                    }
                }
            }
        });

        // ============================================================
        // ৩. স্মার্ট ব্যাক বাটন
        // ============================================================
        function goBack() {
            window.history.back();
        }

        document.addEventListener('DOMContentLoaded', function() {
            const backBtn = document.getElementById('fkSmartBack');
            const currentPath = window.location.pathname;
            
            const noBackPages = ['/', '/home/', '/dashboard/', '/products/'];
            
            let showBack = true;
            for (let i = 0; i < noBackPages.length; i++) {
                if (currentPath === noBackPages[i] || currentPath.startsWith(noBackPages[i])) {
                    showBack = false;
                    break;
                }
            }
            
            if (currentPath.includes('/product/') && currentPath.includes('/detail/')) {
                showBack = true;
            }
            if (currentPath.includes('/orders/') && currentPath.match(/\/\d+\/$/)) {
                showBack = true;
            }
            
            if (backBtn) {
                if (showBack && window.history.length > 1) {
                    backBtn.classList.add('visible');
                } else {
                    backBtn.style.display = 'none';
                }
            }
        });

        // ============================================================
        // ৪. পেজ টাইটেল সেট
        // ============================================================
        document.addEventListener('DOMContentLoaded', function() {
            const titleEl = document.getElementById('fkPageTitle');
            if (titleEl) {
                const pageTitle = document.title || 'Flipkart';
                const cleanTitle = pageTitle.replace(/^Flipkart - /, '');
                titleEl.textContent = cleanTitle;
            }
        });

        // ============================================================
        // ৫. টোস্ট ফাংশন
        // ============================================================
        function showToast(message, type = 'info') {
            const container = document.getElementById('fk-toast-container');
            const toast = document.createElement('div');
            toast.className = `fk-toast ${type}`;
            
            const icons = {
                success: 'fa-check-circle',
                error: 'fa-exclamation-circle',
                info: 'fa-info-circle'
            };
            
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas ${icons[type] || icons.info}"></i></span>
                <span class="toast-msg">${message}</span>
                <button class="toast-close">&times;</button>
            `;
            
            container.appendChild(toast);
            setTimeout(() => toast.classList.add('show'), 10);
            
            toast.querySelector('.toast-close').addEventListener('click', function() {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            });
            
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 4500);
        }

        // ============================================================
        // ৬. অ্যালার্ট অটো ডিসমিস
        // ============================================================
        setTimeout(function() {
            document.querySelectorAll('.alert').forEach(function(alert) {
                const bsAlert = new bootstrap.Alert(alert);
                setTimeout(() => bsAlert.close(), 500);
            });
        }, 5000);

        // ============================================================
        // ৭. ✅ কার্ট ব্যাজ আপডেট - রিয়েল-টাইম
        // ============================================================
        function updateCartBadge(count) {
            const desktopBadge = document.getElementById('cart-badge-desktop');
            if (desktopBadge) {
                if (count > 0) {
                    desktopBadge.textContent = count;
                    desktopBadge.style.display = 'inline-block';
                } else {
                    desktopBadge.textContent = '';
                    desktopBadge.style.display = 'none';
                }
            }
            
            const mobileBadge = document.getElementById('cart-badge-mobile');
            if (mobileBadge) {
                if (count > 0) {
                    mobileBadge.textContent = count;
                    mobileBadge.style.display = 'inline-block';
                } else {
                    mobileBadge.textContent = '';
                    mobileBadge.style.display = 'none';
                }
            }
            
            const dot = document.getElementById('mobile-cart-dot');
            if (dot) {
                dot.style.display = count > 0 ? 'block' : 'none';
            }
        }

        // ============================================================
        // ৮. ✅ AJAX দিয়ে কার্ট ব্যাজ আপডেট
        // ============================================================
        function refreshCartBadge() {
            fetch('/cart/api/count/')
                .then(response => response.json())
                .then(data => {
                    if (data.count !== undefined) {
                        updateCartBadge(data.count);
                    }
                })
                .catch(() => {});
        }

        // ============================================================
        // ৯. উইশলিস্ট ব্যাজ আপডেট
        // ============================================================
        function updateWishlistBadge(count) {
            const badge = document.getElementById('wishlist-badge-desktop');
            if (badge) {
                if (count > 0) {
                    badge.textContent = count;
                    badge.style.display = 'inline-block';
                } else {
                    badge.textContent = '';
                    badge.style.display = 'none';
                }
            }
        }

        // ============================================================
        // ১০. ব্রাউজার ব্যাক/ফরওয়ার্ডে লোডার হাইড
        // ============================================================
        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                const loader = document.getElementById('fkLoader');
                if (loader) {
                    loader.classList.add('hidden');
                    setTimeout(function() {
                        loader.style.display = 'none';
                    }, 500);
                }
            }
        });

        console.log('🚀 Flipkart Style Loaded!');
        console.log('✅ Home Category Tabs: NO loader (data-no-loader)');
        console.log('✅ Mobile Nav & Others: HAS loader');
        console.log('✅ Cart Badge: Real-time update');
    </script>
    
    {% block extra_js %}{% endblock %}
</body>
</html>