<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{% block title %}Flipkart{% endblock %}</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    {% load static %}
    <link rel="stylesheet" href="{% static 'css/style.css' %}">
    <link rel="stylesheet" href="{% static 'css/custom.css' %}">
    
    <style>
        /* ============================================================
           ফ্লিপকার্ট ক্লোন - ক্লিন ডিজাইন
           ============================================================ */
        
        /* ---------- রুট ভেরিয়েবল ---------- */
        :root {
            --primary-blue: #2874f0;
            --primary-orange: #fb641b;
            --primary-yellow: #ffe11b;
            --primary-green: #388e3c;
            --white: #ffffff;
            --light-gray: #f1f3f6;
            --border-gray: #e0e0e0;
            --text-dark: #212121;
            --text-light: #878787;
            --shadow-sm: 0 2px 4px rgba(0,0,0,0.08);
            --shadow-md: 0 4px 12px rgba(0,0,0,0.12);
            --shadow-lg: 0 8px 24px rgba(0,0,0,0.16);
            --radius: 4px;
            --radius-lg: 8px;
            --radius-xl: 12px;
            --transition: all 0.3s ease;
        }
        
        /* ---------- গ্লোবাল ---------- */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--light-gray);
            color: var(--text-dark);
            min-height: 100vh;
            padding-top: 0;
            padding-bottom: 70px;
        }
        
        @media (min-width: 992px) {
            body { padding-bottom: 0; }
        }
        
        /* ============================================================
           অ্যানিমেটেড লোগো
           ============================================================ */
        .fk-logo-container {
            display: flex;
            align-items: center;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .fk-logo-container .logo-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            background: var(--white);
            border-radius: 12px;
            padding: 4px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.1);
        }
        
        .fk-logo-container .logo-icon img {
            height: 100%;
            width: auto;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .fk-logo-container .logo-text {
            font-weight: 700;
            color: var(--white);
            letter-spacing: -0.5px;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            line-height: 1;
        }
        
        .fk-logo-container .logo-text .dot {
            color: var(--primary-yellow);
        }
        
        .fk-logo-container .logo-sub {
            font-size: 10px;
            font-weight: 400;
            color: var(--white);
            opacity: 0.8;
            letter-spacing: 0.5px;
            margin-top: 1px;
        }
        
        .fk-logo-container .logo-sub .plus {
            color: var(--primary-yellow);
            font-weight: 700;
        }
        
        /* ডেস্কটপ লোগো */
        .fk-logo-desktop .logo-icon {
            width: 44px;
            height: 44px;
        }
        
        .fk-logo-desktop .logo-icon img {
            height: 36px;
        }
        
        .fk-logo-desktop .logo-text {
            font-size: 26px;
            margin-left: 10px;
        }
        
        .fk-logo-desktop:hover .logo-icon {
            transform: rotate(-5deg) scale(1.05);
            box-shadow: 0 4px 24px rgba(255,255,255,0.2);
        }
        
        .fk-logo-desktop:hover .logo-text {
            transform: translateX(3px);
        }
        
        /* মোবাইল লোগো */
        .fk-logo-mobile .logo-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
        }
        
        .fk-logo-mobile .logo-icon img {
            height: 26px;
        }
        
        .fk-logo-mobile .logo-text {
            font-size: 18px;
            margin-left: 8px;
        }
        
        .fk-logo-mobile:hover .logo-icon {
            transform: rotate(-5deg) scale(1.05);
        }
        
        /* ============================================================
           লোডিং ওভারলে
           ============================================================ */
        .fk-loader-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(255,255,255,0.92);
            z-index: 99999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 1;
            transition: opacity 0.5s ease, visibility 0.5s ease;
            visibility: visible;
            backdrop-filter: blur(4px);
            pointer-events: none;
        }
        
        .fk-loader-overlay.hidden {
            opacity: 0;
            visibility: hidden;
        }
        
        .fk-loader-overlay .loader-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid var(--border-gray);
            border-top: 4px solid var(--primary-blue);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        .fk-loader-overlay .loader-logo {
            font-size: 22px;
            font-weight: 700;
            color: var(--primary-blue);
            margin-bottom: 16px;
            letter-spacing: -0.5px;
        }
        
        .fk-loader-overlay .loader-logo span {
            color: var(--primary-orange);
        }
        
        .fk-loader-overlay .loader-text {
            margin-top: 12px;
            font-size: 13px;
            color: var(--text-light);
            font-weight: 500;
            animation: textPulse 1.5s ease-in-out infinite;
        }
        
        .fk-loader-overlay .loader-progress {
            width: 160px;
            height: 3px;
            background: var(--border-gray);
            border-radius: 4px;
            margin-top: 10px;
            overflow: hidden;
        }
        
        .fk-loader-overlay .loader-progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--primary-blue), var(--primary-orange));
            border-radius: 4px;
            animation: progressAnim 1.2s ease-in-out infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        @keyframes textPulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }
        
        @keyframes progressAnim {
            0% { width: 0%; }
            50% { width: 70%; }
            100% { width: 100%; }
        }
        
        /* ============================================================
           স্মার্ট ব্যাক বাটন
           ============================================================ */
        .fk-smart-back {
            display: none;
            background: rgba(0,0,0,0.04);
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-dark);
            cursor: pointer;
            transition: all 0.3s ease;
            align-items: center;
            gap: 6px;
            width: fit-content;
            flex-shrink: 0;
        }
        
        .fk-smart-back:hover {
            background: rgba(0,0,0,0.08);
            transform: translateX(-4px);
            color: var(--primary-blue);
        }
        
        .fk-smart-back i {
            font-size: 16px;
        }
        
        .fk-smart-back.visible {
            display: inline-flex;
        }
        
        /* ============================================================
           মোবাইল টপ বার
           ============================================================ */
        .fk-mobile-topbar {
            display: none;
            padding: 10px 14px;
            background: var(--white);
            border-bottom: 1px solid var(--border-gray);
            position: sticky;
            top: 0;
            z-index: 100;
            align-items: center;
            gap: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }
        
        @media (max-width: 991.98px) {
            .fk-mobile-topbar {
                display: flex;
            }
        }
        
        .fk-mobile-topbar .page-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-dark);
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        
        .fk-mobile-topbar .topbar-actions {
            display: flex;
            gap: 4px;
            flex-shrink: 0;
        }
        
        .fk-mobile-topbar .topbar-btn {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: none;
            background: transparent;
            color: var(--text-dark);
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        
        .fk-mobile-topbar .topbar-btn:hover {
            background: var(--light-gray);
        }
        
        .fk-mobile-topbar .topbar-btn .badge-dot {
            position: absolute;
            top: 2px;
            right: 2px;
            width: 8px;
            height: 8px;
            background: var(--primary-orange);
            border-radius: 50%;
            border: 2px solid var(--white);
        }
        
        /* ============================================================
           ডেস্কটপ হেডার
           ============================================================ */
        .fk-desktop-header {
            background: var(--primary-blue);
            padding: 10px 0;
            position: sticky;
            top: 0;
            z-index: 1040;
            box-shadow: 0 2px 12px rgba(0,0,0,0.12);
            display: none;
        }
        
        @media (min-width: 992px) {
            .fk-desktop-header {
                display: block !important;
            }
        }
        
        .fk-desktop-header .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }
        
        .fk-desktop-search {
            flex: 1;
            max-width: 600px;
            min-width: 250px;
            position: relative;
        }
        
        .fk-desktop-search input {
            width: 100%;
            padding: 10px 46px 10px 16px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            background: var(--white);
            color: var(--text-dark);
            outline: none;
            height: 42px;
            transition: all 0.3s ease;
        }
        
        .fk-desktop-search input:focus {
            box-shadow: 0 0 0 2px rgba(255,255,255,0.3);
        }
        
        .fk-desktop-search input::placeholder {
            color: var(--text-light);
            font-size: 13px;
        }
        
        .fk-desktop-search .search-btn {
            position: absolute;
            right: 0;
            top: 0;
            height: 100%;
            width: 46px;
            border: none;
            background: transparent;
            color: var(--primary-blue);
            font-size: 17px;
            cursor: pointer;
            border-radius: 0 6px 6px 0;
            transition: all 0.3s ease;
        }
        
        .fk-desktop-search .search-btn:hover {
            background: rgba(0,0,0,0.04);
            transform: scale(1.05);
        }
        
        .fk-desktop-right {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }
        
        .fk-desktop-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--white);
            background: transparent;
        }
        
        .fk-desktop-btn:hover {
            background: rgba(255,255,255,0.12);
            color: var(--white);
            transform: translateY(-2px);
        }
        
        .fk-desktop-btn.login-btn {
            background: var(--white);
            color: var(--primary-blue);
            padding: 8px 24px;
            font-weight: 600;
            border-radius: 6px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        
        .fk-desktop-btn.login-btn:hover {
            background: #f5f5f5;
            color: var(--primary-blue);
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        }
        
        .fk-desktop-btn .badge-icon {
            background: var(--primary-orange);
            color: var(--white);
            font-size: 10px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 50%;
            min-width: 18px;
            text-align: center;
        }
        
        .fk-desktop-btn .cart-icon {
            font-size: 20px;
            position: relative;
        }
        
        .fk-desktop-btn .cart-badge {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary-orange);
            color: var(--white);
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 50%;
            min-width: 18px;
            text-align: center;
            animation: badgePulse 2s ease-in-out infinite;
        }
        
        @keyframes badgePulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        .fk-desktop-dropdown .dropdown-menu {
            border: none;
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-lg);
            padding: 8px 0;
            min-width: 200px;
            margin-top: 8px;
            border: 1px solid var(--border-gray);
        }
        
        .fk-desktop-dropdown .dropdown-item {
            padding: 10px 18px;
            font-size: 14px;
            color: var(--text-dark);
            transition: all 0.2s ease;
            font-weight: 500;
        }
        
        .fk-desktop-dropdown .dropdown-item:hover {
            background: var(--light-gray);
            color: var(--primary-blue);
            transform: translateX(4px);
        }
        
        .fk-desktop-dropdown .dropdown-item i {
            width: 20px;
            margin-right: 10px;
            color: var(--text-light);
            font-size: 15px;
        }
        
        .fk-desktop-dropdown .dropdown-divider {
            margin: 4px 0;
            border-color: var(--border-gray);
        }
        
        /* ============================================================
           মোবাইল নেভবার (Bottom Navigation)
           ============================================================ */
        .fk-mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            border-top: 1px solid var(--border-gray);
            z-index: 1050;
            padding: 6px 0 10px;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
            display: none;
        }
        
        @media (max-width: 991.98px) {
            .fk-mobile-nav { 
                display: block !important; 
            }
        }
        
        .fk-mobile-nav .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: var(--text-light);
            font-size: 11px;
            font-weight: 500;
            padding: 4px 0;
            transition: all 0.3s ease;
            position: relative;
            gap: 1px;
        }
        
        .fk-mobile-nav .nav-item.active {
            color: var(--primary-blue);
        }
        
        .fk-mobile-nav .nav-item.active i {
            color: var(--primary-blue);
        }
        
        .fk-mobile-nav .nav-item i {
            font-size: 24px;
            margin-bottom: 1px;
            transition: all 0.3s ease;
            color: var(--text-light);
        }
        
        .fk-mobile-nav .nav-item:hover i {
            transform: scale(1.1);
            color: var(--primary-blue);
        }
        
        .fk-mobile-nav .nav-item .nav-badge {
            position: absolute;
            top: 0px;
            right: 50%;
            transform: translateX(calc(50% + 16px));
            background: var(--primary-orange);
            color: var(--white);
            font-size: 10px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 50%;
            min-width: 16px;
            text-align: center;
            animation: badgePulse 2s ease-in-out infinite;
        }
        
        .fk-mobile-nav .nav-item .nav-label {
            font-size: 9px;
            font-weight: 500;
            letter-spacing: 0.3px;
        }
        
        /* ============================================================
           মেইন কন্টেন্ট
           ============================================================ */
        .fk-main {
            padding: 0;
            min-height: calc(100vh - 70px);
        }
        
        @media (min-width: 992px) {
            .fk-main {
                min-height: calc(100vh - 80px);
            }
        }
        
        @media (max-width: 991.98px) {
            .fk-main {
                min-height: calc(100vh - 90px);
            }
        }
        
        /* ============================================================
           ফ্লিপকার্ট কার্ড
           ============================================================ */
        .fk-card {
            background: var(--white);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-sm);
            padding: 16px 18px;
            margin-bottom: 14px;
            border: none;
            transition: all 0.3s ease;
        }
        
        .fk-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }
        
        .fk-card-header {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-dark);
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-gray);
            margin-bottom: 12px;
        }
        
        /* ============================================================
           বাটন
           ============================================================ */
        .fk-btn-primary {
            background: var(--primary-blue);
            color: var(--white);
            border: none;
            padding: 10px 24px;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .fk-btn-primary:hover {
            background: #1a5bc7;
            color: var(--white);
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }
        
        .fk-btn-orange {
            background: var(--primary-orange);
            color: var(--white);
            border: none;
            padding: 10px 24px;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .fk-btn-orange:hover {
            background: #e85a0e;
            color: var(--white);
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }
        
        .fk-btn-outline {
            background: transparent;
            color: var(--primary-blue);
            border: 2px solid var(--primary-blue);
            padding: 8px 22px;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
        }
        .fk-btn-outline:hover {
            background: var(--primary-blue);
            color: var(--white);
            transform: translateY(-3px);
            box-shadow: var(--shadow-sm);
        }
        
        /* ============================================================
           প্রোডাক্ট কার্ড
           ============================================================ */
        .fk-product-card {
            background: var(--white);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            height: 100%;
            border: 1px solid var(--border-gray);
        }
        
        .fk-product-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-8px) scale(1.01);
            border-color: var(--primary-blue);
        }
        
        .fk-product-card .product-image {
            height: 180px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--light-gray);
            padding: 14px;
            position: relative;
            overflow: hidden;
        }
        
        .fk-product-card .product-image img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: transform 0.5s ease;
        }
        
        .fk-product-card:hover .product-image img {
            transform: scale(1.06);
        }
        
        .fk-product-card .product-body {
            padding: 12px 14px 14px;
        }
        
        .fk-product-card .product-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            height: 40px;
            transition: color 0.3s ease;
            line-height: 1.4;
        }
        .fk-product-card:hover .product-title {
            color: var(--primary-blue);
        }
        
        .fk-product-card .product-price {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-dark);
        }
        
        .fk-product-card .product-price .original {
            font-size: 13px;
            font-weight: 400;
            color: var(--text-light);
            text-decoration: line-through;
            margin-left: 6px;
        }
        
        .fk-product-card .product-price .discount {
            font-size: 13px;
            font-weight: 600;
            color: var(--primary-green);
            margin-left: 6px;
        }
        
        .fk-product-card .product-footer {
            padding: 8px 14px 14px;
            border-top: 1px solid var(--border-gray);
            display: flex;
            gap: 6px;
        }
        
        .fk-product-card .product-footer .btn {
            flex: 1;
            font-size: 12px;
            padding: 6px 10px;
            transition: all 0.3s ease;
            border-radius: var(--radius-lg);
            font-weight: 600;
        }
        .fk-product-card .product-footer .btn:hover {
            transform: translateY(-3px);
        }
        
        .fk-discount-tag {
            position: absolute;
            top: 6px;
            left: 6px;
            background: linear-gradient(135deg, var(--primary-orange), #f57c00);
            color: var(--white);
            font-size: 11px;
            font-weight: 700;
            padding: 3px 12px;
            border-radius: 6px;
            animation: discountPulse 2s ease-in-out infinite;
            box-shadow: 0 2px 12px rgba(251, 100, 27, 0.3);
        }
        
        @keyframes discountPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        /* ============================================================
           ফুটার (Desktop Only)
           ============================================================ */
        .fk-footer {
            background: #172337;
            color: var(--white);
            padding: 40px 0 20px;
            margin-top: 28px;
        }
        
        @media (max-width: 991.98px) {
            .fk-footer { display: none !important; }
        }
        
        .fk-footer a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            font-size: 13px;
            transition: all 0.3s ease;
            padding: 3px 0;
            display: inline-block;
        }
        .fk-footer a:hover {
            color: var(--white);
            transform: translateX(6px);
        }
        
        .fk-footer h6 {
            color: var(--white);
            font-weight: 700;
            font-size: 15px;
            margin-bottom: 12px;
            opacity: 0.9;
            letter-spacing: 0.5px;
        }
        
        .fk-footer .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.08);
            padding-top: 16px;
            margin-top: 24px;
            text-align: center;
            font-size: 13px;
            color: rgba(255,255,255,0.5);
        }
        
        /* ============================================================
           টোস্ট
           ============================================================ */
        .fk-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            background: var(--white);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-lg);
            padding: 14px 20px;
            max-width: 360px;
            display: flex;
            align-items: center;
            gap: 10px;
            transform: translateX(120%);
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            border-left: 5px solid var(--primary-blue);
        }
        
        .fk-toast.show { transform: translateX(0); }
        .fk-toast.success { border-left-color: var(--primary-green); }
        .fk-toast.error { border-left-color: #dc3545; }
        
        .fk-toast .toast-icon { font-size: 22px; }
        .fk-toast .toast-msg { font-size: 13px; font-weight: 500; color: var(--text-dark); flex: 1; }
        .fk-toast .toast-close {
            background: none;
            border: none;
            font-size: 18px;
            color: var(--text-light);
            cursor: pointer;
            padding: 0 4px;
            transition: transform 0.3s ease;
        }
        .fk-toast .toast-close:hover { transform: rotate(90deg); }
        
        @media (max-width: 575.98px) {
            .fk-toast { top: 12px; right: 12px; max-width: 280px; padding: 10px 14px; }
            .fk-toast .toast-icon { font-size: 18px; }
            .fk-toast .toast-msg { font-size: 12px; }
        }
        
        /* ============================================================
           ইউটিলিটি
           ============================================================ */
        .text-blue { color: var(--primary-blue); }
        .text-orange { color: var(--primary-orange); }
        .bg-blue { background: var(--primary-blue); }
        .bg-orange { background: var(--primary-orange); }
        .bg-light-gray { background: var(--light-gray); }
        .fk-shadow { box-shadow: var(--shadow-sm); }
        .fk-shadow-hover:hover { box-shadow: var(--shadow-md); }
        .fk-radius { border-radius: var(--radius-xl); }
        .gap-2 { gap: 8px; }
        .gap-3 { gap: 12px; }
        .fw-500 { font-weight: 500; }
        .fw-600 { font-weight: 600; }
        .fw-700 { font-weight: 700; }
        
        /* ============================================================
           ডেস্কটপ অ্যাডজাস্টমেন্ট
           ============================================================ */
        @media (min-width: 992px) {
            .fk-product-card .product-image { height: 220px; }
            .fk-product-card .product-title { font-size: 15px; height: 44px; }
            .fk-product-card .product-price { font-size: 19px; }
            .fk-product-card .product-footer .btn { font-size: 13px; padding: 8px 12px; }
            .fk-card { padding: 20px 24px; margin-bottom: 20px; }
            .fk-card-header { font-size: 18px; }
            .fk-main { max-width: 1400px; margin: 0 auto; }
        }
        
        /* ============================================================
           মোবাইল অ্যাডজাস্টমেন্ট
           ============================================================ */
        @media (max-width: 575.98px) {
            .fk-product-card .product-image { height: 140px; }
            .fk-product-card .product-title { font-size: 13px; height: 36px; }
            .fk-product-card .product-price { font-size: 16px; }
            .fk-product-card .product-footer .btn { font-size: 11px; padding: 5px 8px; }
            .fk-card { padding: 10px 12px; margin-bottom: 10px; }
            .fk-card-header { font-size: 15px; }
            .fk-mobile-nav .nav-item i { font-size: 22px; }
            .fk-mobile-nav .nav-item .nav-label { font-size: 8px; }
            .fk-mobile-nav { padding: 4px 0 8px; }
            .fk-mobile-topbar { padding: 8px 12px; }
            .fk-mobile-topbar .page-title { font-size: 13px; }
        }
    </style>
</head>
<body>

