        <div class="container">
            <div class="row g-4">
                <div class="col-md-3 col-6">
                    <h6>ABOUT</h6>
                    <a href="#" class="d-block">Contact Us</a>
                    <a href="#" class="d-block">About Us</a>
                    <a href="#" class="d-block">Careers</a>
                    <a href="#" class="d-block">Flipkart Stories</a>
                    <a href="#" class="d-block">Press</a>
                </div>
                <div class="col-md-3 col-6">
                    <h6>HELP</h6>
                    <a href="#" class="d-block">Payments</a>
