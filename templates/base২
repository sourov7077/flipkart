<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{% block title %}Flipkart - Online Shopping in Bangladesh{% endblock %}</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    {% load static %}
    <link rel="stylesheet" href="{% static 'css/style.css' %}">
    <link rel="stylesheet" href="{% static 'css/custom.css' %}">
    
    <style>
        /* ============================================================
           ফ্লিপকার্ট ক্লোন - ক্লিন ডিজাইন (Desktop + Mobile)
           ============================================================ */
        
        /* ---------- রুট ভেরিয়েবল ---------- */
        :root {
            --primary-blue: #2874f0;
            --primary-orange: #fb641b;
            --primary-yellow: #ffe11b;
            --primary-green: #388e3c;
            --white: #ffffff;
            --light-gray: #f1f3f6;
            --border-gray: #e0e0e0;
            --text-dark: #212121;
            --text-light: #878787;
            --shadow-sm: 0 2px 4px rgba(0,0,0,0.08);
            --shadow-md: 0 4px 12px rgba(0,0,0,0.12);
            --shadow-lg: 0 8px 24px rgba(0,0,0,0.16);
            --radius: 4px;
            --radius-lg: 8px;
            --radius-xl: 12px;
            --transition: all 0.3s ease;
        }
        
        /* ---------- গ্লোবাল ---------- */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--light-gray);
            color: var(--text-dark);
            min-height: 100vh;
            padding-top: 0;
            padding-bottom: 70px;
        }
        
        /* ডেস্কটপে padding কম */
        @media (min-width: 992px) {
            body { padding-bottom: 0; }
        }
        
        /* স্ক্রলবার */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: var(--primary-blue); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #1a5bc7; }
        
        /* ============================================================
           ডেস্কটপ হেডার (Desktop Only)
           ============================================================ */
        .fk-desktop-header {
            background: var(--primary-blue);
            padding: 12px 0;
            position: sticky;
            top: 0;
            z-index: 1040;
            box-shadow: 0 2px 12px rgba(0,0,0,0.12);
            display: none;
        }
        
        @media (min-width: 992px) {
            .fk-desktop-header {
                display: block !important;
            }
        }
        
        .fk-desktop-header .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
        }
        
        /* লোগো */
        .fk-desktop-logo {
            display: flex;
            align-items: center;
            text-decoration: none;
            flex-shrink: 0;
        }
        
        .fk-desktop-logo img {
            height: 38px;
            width: auto;
            transition: transform 0.3s ease;
        }
        
        .fk-desktop-logo:hover img {
            transform: scale(1.04) rotate(-1deg);
        }
        
        .fk-desktop-logo-text {
            color: var(--white);
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-left: 6px;
        }
        
        .fk-desktop-logo-text span {
            color: var(--primary-yellow);
        }
        
        .fk-desktop-logo-sub {
            font-size: 11px;
            font-weight: 400;
            color: var(--white);
            opacity: 0.9;
            display: block;
            margin-top: -2px;
        }
        
        .fk-desktop-logo-sub .plus-icon {
            color: var(--primary-yellow);
            font-weight: 700;
        }
        
        /* সার্চ */
        .fk-desktop-search {
            flex: 1;
            max-width: 600px;
            min-width: 300px;
            position: relative;
        }
        
        .fk-desktop-search input {
            width: 100%;
            padding: 12px 50px 12px 18px;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            background: var(--white);
            color: var(--text-dark);
            outline: none;
            box-shadow: 0 0 0 1px rgba(255,255,255,0.15);
            transition: all 0.3s ease;
            height: 46px;
        }
        
        .fk-desktop-search input:focus {
            box-shadow: 0 0 0 2px rgba(255,255,255,0.3);
            background: #f8f9fa;
        }
        
        .fk-desktop-search input::placeholder {
            color: var(--text-light);
            font-size: 14px;
        }
        
        .fk-desktop-search .search-btn {
            position: absolute;
            right: 0;
            top: 0;
            height: 100%;
            width: 50px;
            border: none;
            background: transparent;
            color: var(--primary-blue);
            font-size: 18px;
            cursor: pointer;
            border-radius: 0 6px 6px 0;
            transition: all 0.3s ease;
        }
        
        .fk-desktop-search .search-btn:hover {
            background: rgba(0,0,0,0.04);
            transform: scale(1.05);
        }
        
        /* হেডার রাইট */
        .fk-desktop-right {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }
        
        .fk-desktop-btn {
            padding: 10px 18px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--white);
            background: transparent;
        }
        
        .fk-desktop-btn:hover {
            background: rgba(255,255,255,0.12);
            color: var(--white);
            transform: translateY(-2px);
        }
        
        .fk-desktop-btn.login-btn {
            background: var(--white);
            color: var(--primary-blue);
            padding: 10px 28px;
            font-weight: 600;
            border-radius: 6px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        
        .fk-desktop-btn.login-btn:hover {
            background: #f5f5f5;
            color: var(--primary-blue);
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        }
        
        .fk-desktop-btn .badge-icon {
            background: var(--primary-orange);
            color: var(--white);
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 50%;
            margin-left: 4px;
            min-width: 20px;
            text-align: center;
        }
        
        .fk-desktop-btn .cart-icon {
            font-size: 22px;
            position: relative;
        }
        
        .fk-desktop-btn .cart-badge {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--primary-orange);
            color: var(--white);
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 50%;
            min-width: 18px;
            text-align: center;
            animation: badgePulse 2s ease-in-out infinite;
        }
        
        @keyframes badgePulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        /* ড্রপডাউন */
        .fk-desktop-dropdown .dropdown-menu {
            border: none;
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-lg);
            padding: 8px 0;
            min-width: 200px;
            margin-top: 8px;
            border: 1px solid var(--border-gray);
        }
        
        .fk-desktop-dropdown .dropdown-item {
            padding: 12px 20px;
            font-size: 14px;
            color: var(--text-dark);
            transition: all 0.2s ease;
            font-weight: 500;
        }
        
        .fk-desktop-dropdown .dropdown-item:hover {
            background: var(--light-gray);
            color: var(--primary-blue);
            transform: translateX(4px);
        }
        
        .fk-desktop-dropdown .dropdown-item i {
            width: 22px;
            margin-right: 12px;
            color: var(--text-light);
            font-size: 16px;
        }
        
        .fk-desktop-dropdown .dropdown-divider {
            margin: 6px 0;
            border-color: var(--border-gray);
        }
        
        /* ============================================================
           মোবাইল নেভবার (Bottom Navigation - Phone Only)
           ============================================================ */
        .fk-mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            border-top: 1px solid var(--border-gray);
            z-index: 1050;
            padding: 8px 0 12px;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
            display: none;
        }
        
        @media (max-width: 991.98px) {
            .fk-mobile-nav { 
                display: block !important; 
            }
        }
        
        .fk-mobile-nav .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: var(--text-light);
            font-size: 11px;
            font-weight: 500;
            padding: 6px 0;
            transition: all 0.3s ease;
            position: relative;
            gap: 2px;
        }
        
        .fk-mobile-nav .nav-item.active {
            color: var(--primary-blue);
        }
        
        .fk-mobile-nav .nav-item.active i {
            color: var(--primary-blue);
        }
        
        .fk-mobile-nav .nav-item i {
            font-size: 26px;
            margin-bottom: 2px;
            transition: all 0.3s ease;
            color: var(--text-light);
        }
        
        .fk-mobile-nav .nav-item:hover i {
            transform: scale(1.1);
            color: var(--primary-blue);
        }
        
        .fk-mobile-nav .nav-item .nav-badge {
            position: absolute;
            top: 2px;
            right: 50%;
            transform: translateX(calc(50% + 18px));
            background: var(--primary-orange);
            color: var(--white);
            font-size: 10px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 50%;
            min-width: 18px;
            text-align: center;
            animation: badgePulse 2s ease-in-out infinite;
        }
        
        .fk-mobile-nav .nav-item .nav-label {
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 0.3px;
        }
        
        /* ============================================================
           মেইন কন্টেন্ট
           ============================================================ */
        .fk-main {
            padding: 0;
            min-height: calc(100vh - 70px);
        }
        
        @media (min-width: 992px) {
            .fk-main {
                padding: 0;
                min-height: calc(100vh - 80px);
            }
        }
        
        @media (max-width: 991.98px) {
            .fk-main {
                padding: 0;
                min-height: calc(100vh - 90px);
            }
        }
        
        /* ============================================================
           ফ্লিপকার্ট কার্ড
           ============================================================ */
        .fk-card {
            background: var(--white);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-sm);
            padding: 18px 20px;
            margin-bottom: 16px;
            border: none;
            transition: all 0.3s ease;
        }
        
        .fk-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }
        
        .fk-card-header {
            font-size: 17px;
            font-weight: 600;
            color: var(--text-dark);
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border-gray);
            margin-bottom: 14px;
        }
        
        /* ============================================================
           বাটন (বড় সাইজ)
           ============================================================ */
        .fk-btn-primary {
            background: var(--primary-blue);
            color: var(--white);
            border: none;
            padding: 12px 28px;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .fk-btn-primary:hover {
            background: #1a5bc7;
            color: var(--white);
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }
        
        .fk-btn-orange {
            background: var(--primary-orange);
            color: var(--white);
            border: none;
            padding: 12px 28px;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .fk-btn-orange:hover {
            background: #e85a0e;
            color: var(--white);
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }
        
        .fk-btn-outline {
            background: transparent;
            color: var(--primary-blue);
            border: 2px solid var(--primary-blue);
            padding: 10px 26px;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
        }
        .fk-btn-outline:hover {
            background: var(--primary-blue);
            color: var(--white);
            transform: translateY(-3px);
            box-shadow: var(--shadow-sm);
        }
        
        /* ============================================================
           প্রোডাক্ট কার্ড (বড় সাইজ)
           ============================================================ */
        .fk-product-card {
            background: var(--white);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            height: 100%;
            border: 1px solid var(--border-gray);
        }
        
        .fk-product-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-8px) scale(1.01);
            border-color: var(--primary-blue);
        }
        
        .fk-product-card .product-image {
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--light-gray);
            padding: 16px;
            position: relative;
            overflow: hidden;
        }
        
        .fk-product-card .product-image img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: transform 0.5s ease;
        }
        
        .fk-product-card:hover .product-image img {
            transform: scale(1.06);
        }
        
        .fk-product-card .product-body {
            padding: 14px 16px 16px;
        }
        
        .fk-product-card .product-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            height: 42px;
            transition: color 0.3s ease;
            line-height: 1.4;
        }
        .fk-product-card:hover .product-title {
            color: var(--primary-blue);
        }
        
        .fk-product-card .product-price {
            font-size: 19px;
            font-weight: 700;
            color: var(--text-dark);
        }
        
        .fk-product-card .product-price .original {
            font-size: 14px;
            font-weight: 400;
            color: var(--text-light);
            text-decoration: line-through;
            margin-left: 8px;
        }
        
        .fk-product-card .product-price .discount {
            font-size: 14px;
            font-weight: 600;
            color: var(--primary-green);
            margin-left: 8px;
        }
        
        .fk-product-card .product-footer {
            padding: 10px 16px 16px;
            border-top: 1px solid var(--border-gray);
            display: flex;
            gap: 8px;
        }
        
        .fk-product-card .product-footer .btn {
            flex: 1;
            font-size: 13px;
            padding: 8px 12px;
            transition: all 0.3s ease;
            border-radius: var(--radius-lg);
            font-weight: 600;
        }
        .fk-product-card .product-footer .btn:hover {
            transform: translateY(-3px);
        }
        
        .fk-discount-tag {
            position: absolute;
            top: 8px;
            left: 8px;
            background: linear-gradient(135deg, var(--primary-orange), #f57c00);
            color: var(--white);
            font-size: 12px;
            font-weight: 700;
            padding: 4px 14px;
            border-radius: 6px;
            animation: discountPulse 2s ease-in-out infinite;
            box-shadow: 0 2px 12px rgba(251, 100, 27, 0.3);
        }
        
        @keyframes discountPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        /* ============================================================
           ফুটার (Desktop Only) - বড় সাইজ
           ============================================================ */
        .fk-footer {
            background: #172337;
            color: var(--white);
            padding: 48px 0 24px;
            margin-top: 32px;
        }
        
        @media (max-width: 991.98px) {
            .fk-footer { display: none !important; }
        }
        
        .fk-footer a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s ease;
            padding: 4px 0;
            display: inline-block;
        }
        .fk-footer a:hover {
            color: var(--white);
            transform: translateX(6px);
        }
        
        .fk-footer h6 {
            color: var(--white);
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 14px;
            opacity: 0.9;
            letter-spacing: 0.5px;
        }
        
        .fk-footer .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.08);
            padding-top: 20px;
            margin-top: 28px;
            text-align: center;
            font-size: 14px;
            color: rgba(255,255,255,0.5);
        }
        
        /* ============================================================
           টোস্ট
           ============================================================ */
        .fk-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            background: var(--white);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-lg);
            padding: 16px 22px;
            max-width: 380px;
            display: flex;
            align-items: center;
            gap: 12px;
            transform: translateX(120%);
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            border-left: 5px solid var(--primary-blue);
        }
        
        .fk-toast.show { transform: translateX(0); }
        .fk-toast.success { border-left-color: var(--primary-green); }
        .fk-toast.error { border-left-color: #dc3545; }
        
        .fk-toast .toast-icon { font-size: 24px; }
        .fk-toast .toast-msg { font-size: 14px; font-weight: 500; color: var(--text-dark); flex: 1; }
        .fk-toast .toast-close {
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-light);
            cursor: pointer;
            padding: 0 4px;
            transition: transform 0.3s ease;
        }
        .fk-toast .toast-close:hover { transform: rotate(90deg); }
        
        @media (max-width: 575.98px) {
            .fk-toast { top: 12px; right: 12px; max-width: 290px; padding: 12px 16px; }
            .fk-toast .toast-icon { font-size: 20px; }
            .fk-toast .toast-msg { font-size: 13px; }
        }
        
        /* ============================================================
           ইউটিলিটি
           ============================================================ */
        .text-blue { color: var(--primary-blue); }
        .text-orange { color: var(--primary-orange); }
        .bg-blue { background: var(--primary-blue); }
        .bg-orange { background: var(--primary-orange); }
        .bg-light-gray { background: var(--light-gray); }
        .fk-shadow { box-shadow: var(--shadow-sm); }
        .fk-shadow-hover:hover { box-shadow: var(--shadow-md); }
        .fk-radius { border-radius: var(--radius-xl); }
        .gap-2 { gap: 8px; }
        .gap-3 { gap: 12px; }
        .fw-500 { font-weight: 500; }
        .fw-600 { font-weight: 600; }
        .fw-700 { font-weight: 700; }
        
        /* লোডার */
        .fk-loader {
            display: inline-block;
            width: 40px;
            height: 40px;
            border: 3px solid var(--border-gray);
            border-top: 3px solid var(--primary-blue);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        /* ============================================================
           ডেস্কটপ অ্যাডজাস্টমেন্ট
           ============================================================ */
        @media (min-width: 992px) {
            .fk-product-card .product-image { height: 240px; }
            .fk-product-card .product-title { font-size: 16px; height: 46px; }
            .fk-product-card .product-price { font-size: 20px; }
            .fk-product-card .product-footer .btn { font-size: 14px; padding: 10px 14px; }
            .fk-card { padding: 24px 28px; margin-bottom: 24px; }
            .fk-card-header { font-size: 20px; }
            .fk-main { max-width: 1400px; margin: 0 auto; }
        }
        
        /* ============================================================
           মোবাইল অ্যাডজাস্টমেন্ট
           ============================================================ */
        @media (max-width: 575.98px) {
            .fk-product-card .product-image { height: 160px; }
            .fk-product-card .product-title { font-size: 14px; height: 38px; }
            .fk-product-card .product-price { font-size: 17px; }
            .fk-product-card .product-footer .btn { font-size: 12px; padding: 6px 8px; }
            .fk-card { padding: 12px 14px; margin-bottom: 12px; }
            .fk-card-header { font-size: 16px; }
            .fk-mobile-nav .nav-item i { font-size: 24px; }
            .fk-mobile-nav .nav-item .nav-label { font-size: 9px; }
            .fk-mobile-nav { padding: 6px 0 10px; }
        }
    </style>
</head>
<body>

    <!-- ============================================================
    ডেস্কটপ হেডার (Desktop Only)
    ============================================================ -->
    <header class="fk-desktop-header">
        <div class="container">
            <!-- লোগো -->
            <a href="{% url 'home:home' %}" class="fk-desktop-logo">
                <img src="https://static-assets-web.flixcart.com/batman-returns/batman-returns/p/images/logo_lite-cbb357.png" 
                     alt="Flipkart" onerror="this.style.display='none'">
                <div>
                    <span class="fk-desktop-logo-text">Flipkart<span>.</span></span>
                    <span class="fk-desktop-logo-sub">
                        <span class="plus-icon">+</span> Explore <span class="plus-icon">Plus</span>
                    </span>
                </div>
            </a>
            
            <!-- সার্চ -->
            <div class="fk-desktop-search">
                <form method="GET" action="{% url 'products:product_list' %}">
                    <input type="text" name="q" placeholder="Search for products, brands and more" value="{{ request.GET.q|default:'' }}">
                    <button type="submit" class="search-btn">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
            </div>
            
            <!-- হেডার রাইট -->
            <div class="fk-desktop-right">
                {% if user.is_authenticated %}
                <div class="fk-desktop-dropdown">
                    <button class="fk-desktop-btn" data-bs-toggle="dropdown">
                        <i class="fas fa-user-circle"></i>
                        <span>{{ user.first_name|default:user.username }}</span>
                        <i class="fas fa-chevron-down" style="font-size: 10px; margin-left: 4px;"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="{% url 'accounts:dashboard' %}"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                        <li><a class="dropdown-item" href="{% url 'accounts:profile_update' %}"><i class="fas fa-user-edit"></i> Profile</a></li>
                        <li><a class="dropdown-item" href="{% url 'orders:order_history' %}"><i class="fas fa-history"></i> Orders</a></li>
                        <li><a class="dropdown-item" href="{% url 'wishlist:wishlist_view' %}"><i class="fas fa-heart"></i> Wishlist</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form method="post" action="{% url 'accounts:logout' %}" class="d-inline w-100">
                                {% csrf_token %}
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
                {% else %}
                <a href="{% url 'accounts:login' %}" class="fk-desktop-btn login-btn">
                    <i class="fas fa-user"></i> Login
                </a>
                {% endif %}
                
                <a href="{% url 'wishlist:wishlist_view' %}" class="fk-desktop-btn">
                    <i class="fas fa-heart"></i>
                    <span>Wishlist</span>
                    {% if user.is_authenticated and user.wishlist.item_count > 0 %}
                    <span class="badge-icon">{{ user.wishlist.item_count }}</span>
                    {% endif %}
                </a>
                
                <a href="{% url 'cart:cart_detail' %}" class="fk-desktop-btn" style="position: relative;">
                    <span class="cart-icon">
                        <i class="fas fa-shopping-cart"></i>
                        {% if user.is_authenticated and user.cart.total_items > 0 %}
                        <span class="cart-badge">{{ user.cart.total_items }}</span>
                        {% endif %}
                    </span>
                    <span>Cart</span>
                </a>
            </div>
        </div>
    </header>

    <!-- ============================================================
    মেসেজ
    ============================================================ -->
    <div class="container-fluid px-2 px-sm-3 mt-2">
        {% if messages %}
            {% for message in messages %}
                <div class="alert alert-{{ message.tags }} alert-dismissible fade show fk-radius shadow-sm" role="alert" style="padding: 12px 16px; font-size: 14px; border-radius: 8px !important;">
                    <i class="fas fa-{% if message.tags == 'success' %}check-circle text-success{% elif message.tags == 'error' %}exclamation-circle text-danger{% else %}info-circle text-primary{% endif %} me-2"></i>
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" style="padding: 8px;"></button>
                </div>
            {% endfor %}
        {% endif %}
    </div>

    <!-- ============================================================
    মেইন কন্টেন্ট
    ============================================================ -->
    <main class="fk-main">
        {% block content %}
        {% endblock %}
    </main>

    <!-- ============================================================
    ফুটার (Desktop Only)
    ============================================================ -->
