{% extends 'base.html' %}
{% load static %}

{% block title %}Admin Dashboard - Flipkart{% endblock %}

{% block content %}
<div class="row g-3">
    <!-- ============================================================
    ড্যাশবোর্ড হেডার
    ============================================================ -->
    <div class="col-12">
        <div class="fk-card">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h5 class="fw-700 mb-0" style="font-size: 20px;">
                        <i class="fas fa-chart-line text-blue me-2"></i>
                        Admin Dashboard
                    </h5>
                    <p class="text-muted mb-0" style="font-size: 14px;">
                        <i class="fas fa-calendar-alt me-2"></i>
                        {{ today|date:"F d, Y" }}
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm rounded-0" style="font-size: 13px;" onclick="location.reload()">
                        <i class="fas fa-sync me-1"></i> Refresh
                    </button>
                    <a href="/admin/" class="btn fk-btn-primary btn-sm rounded-0" style="font-size: 13px;">
                        <i class="fas fa-cog me-1"></i> Admin Panel
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- ============================================================
    স্ট্যাট কার্ডস
    ============================================================ -->
    <div class="col-12">
        <div class="row g-3">
            <!-- টোটাল অর্ডার -->
            <div class="col-md-3 col-6">
                <div class="fk-card text-center p-3">
                    <div class="stat-icon mb-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle" 
                             style="width: 48px; height: 48px;">
                            <i class="fas fa-shopping-bag text-primary" style="font-size: 22px;"></i>
                        </div>
                    </div>
                    <h3 class="fw-700 mb-0" style="font-size: 24px;">{{ total_orders }}</h3>
                    <p class="text-muted mb-0" style="font-size: 13px;">Total Orders</p>
                    <small class="text-success">
                        <i class="fas fa-arrow-up me-1"></i> {{ weekly_orders }} this week
                    </small>
                </div>
            </div>
            
            <!-- টোটাল রেভিনিউ -->
            <div class="col-md-3 col-6">
                <div class="fk-card text-center p-3">
                    <div class="stat-icon mb-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 rounded-circle" 
                             style="width: 48px; height: 48px;">
                            <i class="fas fa-money-bill-wave text-success" style="font-size: 22px;"></i>
                        </div>
                    </div>
                    <h3 class="fw-700 mb-0" style="font-size: 24px;">₹{{ total_revenue|floatformat:0 }}</h3>
                    <p class="text-muted mb-0" style="font-size: 13px;">Total Revenue</p>
                    <small class="text-success">
                        <i class="fas fa-arrow-up me-1"></i> ₹{{ weekly_revenue|floatformat:0 }} this week
                    </small>
                </div>
            </div>
            
            <!-- পেন্ডিং অর্ডার -->
            <div class="col-md-3 col-6">
                <div class="fk-card text-center p-3">
                    <div class="stat-icon mb-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 rounded-circle" 
                             style="width: 48px; height: 48px;">
                            <i class="fas fa-clock text-warning" style="font-size: 22px;"></i>
                        </div>
                    </div>
                    <h3 class="fw-700 mb-0" style="font-size: 24px;">{{ pending_orders }}</h3>
                    <p class="text-muted mb-0" style="font-size: 13px;">Pending Orders</p>
                    <small class="text-warning">
                        <i class="fas fa-exclamation-circle me-1"></i> Needs attention
                    </small>
                </div>
            </div>
            
            <!-- টোটাল ইউজার -->
            <div class="col-md-3 col-6">
                <div class="fk-card text-center p-3">
                    <div class="stat-icon mb-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-info bg-opacity-10 rounded-circle" 
                             style="width: 48px; height: 48px;">
                            <i class="fas fa-users text-info" style="font-size: 22px;"></i>
                        </div>
                    </div>
                    <h3 class="fw-700 mb-0" style="font-size: 24px;">{{ total_users }}</h3>
                    <p class="text-muted mb-0" style="font-size: 13px;">Total Users</p>
                    <small class="text-success">
                        <i class="fas fa-arrow-up me-1"></i> {{ new_users_week }} new this week
                    </small>
                </div>
            </div>
        </div>
    </div>
    
    <!-- ============================================================
    চার্ট + কুইক স্ট্যাট
    ============================================================ -->
    <div class="col-lg-8">
        <div class="fk-card">
            <div class="fk-card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-chart-bar text-blue me-2"></i> Weekly Sales</span>
                <span class="text-muted" style="font-size: 12px;">Last 7 days</span>
            </div>
            <div style="height: 280px; position: relative;">
                <canvas id="salesChart"></canvas>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="fk-card">
            <div class="fk-card-header">
                <span><i class="fas fa-bolt text-warning me-2"></i> Quick Stats</span>
            </div>
            <div class="quick-stats">
                <div class="d-flex justify-content-between py-2 border-bottom" style="border-color: var(--border-gray) !important;">
                    <span style="font-size: 14px;">Today's Orders</span>
                    <span class="badge bg-primary rounded-0" style="font-size: 14px; padding: 4px 12px;">{{ today_orders }}</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom" style="border-color: var(--border-gray) !important;">
                    <span style="font-size: 14px;">Weekly Revenue</span>
                    <span class="badge bg-success rounded-0" style="font-size: 14px; padding: 4px 12px;">₹{{ weekly_revenue|floatformat:0 }}</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom" style="border-color: var(--border-gray) !important;">
                    <span style="font-size: 14px;">New Users (Week)</span>
                    <span class="badge bg-info rounded-0" style="font-size: 14px; padding: 4px 12px;">{{ new_users_week }}</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom" style="border-color: var(--border-gray) !important;">
                    <span style="font-size: 14px;">Weekly Orders</span>
                    <span class="badge bg-warning rounded-0" style="font-size: 14px; padding: 4px 12px;">{{ weekly_orders }}</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span style="font-size: 14px;">Pending Orders</span>
                    <span class="badge bg-danger rounded-0" style="font-size: 14px; padding: 4px 12px;">{{ pending_orders }}</span>
                </div>
            </div>
        </div>
    </div>
    
    <!-- ============================================================
    টপ সেলিং প্রোডাক্ট
    ============================================================ -->
    <div class="col-lg-6">
        <div class="fk-card">
            <div class="fk-card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-crown text-warning me-2"></i> Top Selling Products</span>
                <span class="text-muted" style="font-size: 12px;">This week</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size: 14px;">
                    <thead style="background: var(--light-gray);">
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Sold</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in top_products %}
                        <tr>
                            <td>{{ forloop.counter }}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    {% if product.get_image_url %}
                                    <img src="{{ product.get_image_url }}" 
                                         alt="{{ product.name }}" 
                                         style="width: 32px; height: 32px; object-fit: contain;">
                                    {% else %}
                                    <i class="fas fa-image text-muted" style="font-size: 20px;"></i>
                                    {% endif %}
                                    <span>{{ product.name|truncatechars:20 }}</span>
                                </div>
                            </td>
                            <td>{{ product.category.name|default:"-" }}</td>
                            <td class="fw-600">₹{{ product.price }}</td>
                            <td>
                                <span class="badge bg-primary rounded-0">{{ product.total_sold|default:0 }}</span>
                            </td>
                        </tr>
                        {% empty %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">No sales data available</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- ============================================================
    রিসেন্ট অর্ডার
    ============================================================ -->
    <div class="col-lg-6">
        <div class="fk-card">
            <div class="fk-card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-clock text-info me-2"></i> Recent Orders</span>
                <a href="{% url 'orders:order_history' %}" class="text-blue text-decoration-none" style="font-size: 13px;">
                    View All <i class="fas fa-chevron-right ms-1" style="font-size: 10px;"></i>
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size: 14px;">
                    <thead style="background: var(--light-gray);">
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in recent_orders %}
                        <tr>
                            <td>
                                <span class="fw-600">#{{ order.order_number|truncatechars:8 }}</span>
                            </td>
                            <td>{{ order.user.username }}</td>
                            <td class="fw-600">₹{{ order.total }}</td>
                            <td>
                                {% if order.status == 'delivered' %}
                                <span class="badge bg-success rounded-0">Delivered</span>
                                {% elif order.status == 'pending' %}
                                <span class="badge bg-warning rounded-0">Pending</span>
                                {% elif order.status == 'processing' %}
                                <span class="badge bg-info rounded-0">Processing</span>
                                {% elif order.status == 'shipped' %}
                                <span class="badge bg-primary rounded-0">Shipped</span>
                                {% elif order.status == 'cancelled' %}
                                <span class="badge bg-danger rounded-0">Cancelled</span>
                                {% else %}
                                <span class="badge bg-secondary rounded-0">{{ order.get_status_display }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% empty %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-3">No recent orders</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- ============================================================
    লো স্টক অ্যালার্ট
    ============================================================ -->
    {% if low_stock %}
    <div class="col-12">
        <div class="fk-card border-left-danger" style="border-left: 4px solid #dc3545;">
            <div class="fk-card-header d-flex justify-content-between align-items-center" style="border-bottom-color: #dc3545;">
                <span class="text-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i> Low Stock Alert
                </span>
                <span class="badge bg-danger rounded-0">{{ low_stock|length }} products</span>
            </div>
            <div class="row g-2">
                {% for product in low_stock %}
                <div class="col-md-3 col-6">
                    <div class="border p-2 text-center" style="border-color: var(--border-gray) !important;">
                        <div class="d-flex align-items-center justify-content-center gap-2">
                            {% if product.get_image_url %}
                            <img src="{{ product.get_image_url }}" 
                                 alt="{{ product.name }}" 
                                 style="width: 30px; height: 30px; object-fit: contain;">
                            {% else %}
                            <i class="fas fa-image text-muted" style="font-size: 18px;"></i>
                            {% endif %}
                            <div>
                                <p class="mb-0 fw-600" style="font-size: 12px;">{{ product.name|truncatechars:12 }}</p>
                                <p class="mb-0 text-danger fw-700" style="font-size: 13px;">Stock: {{ product.stock }}</p>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}
</div>

<!-- ============================================================
   স্টাইল ওভাররাইড
   ============================================================ -->
<style>
    .fk-card {
        border-radius: 0 !important;
        box-shadow: var(--shadow-sm);
    }
    .fk-card:hover {
        box-shadow: var(--shadow-md);
    }
    .fk-card-header {
        font-size: 15px;
        font-weight: 600;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border-gray);
        margin-bottom: 12px;
    }
    .border-left-danger {
        border-left: 4px solid #dc3545 !important;
    }
    .stat-icon .rounded-circle {
        transition: all 0.3s ease;
    }
    .fk-card:hover .stat-icon .rounded-circle {
        transform: scale(1.1);
    }
    .table {
        border-collapse: collapse;
    }
    .table th {
        font-weight: 600;
        color: var(--text-dark);
        border-bottom: 2px solid var(--border-gray);
        padding: 10px 12px;
        font-size: 13px;
    }
    .table td {
        padding: 10px 12px;
        vertical-align: middle;
        font-size: 13px;
    }
    .table-hover tbody tr:hover {
        background: var(--light-gray);
    }
    .badge {
        border-radius: 0 !important;
        font-weight: 600;
        padding: 4px 12px;
        font-size: 12px;
    }
    .btn-outline-secondary {
        border-radius: 0 !important;
        border-color: var(--border-gray);
        color: var(--text-dark);
    }
    .btn-outline-secondary:hover {
        background: var(--light-gray);
        border-color: var(--border-gray);
        color: var(--text-dark);
    }
    .fk-btn-primary {
        border-radius: 0 !important;
    }
    .bg-primary {
        background-color: var(--primary-blue) !important;
    }
    .bg-success {
        background-color: #388e3c !important;
    }
    .bg-warning {
        background-color: #ffc107 !important;
    }
    .bg-info {
        background-color: #17a2b8 !important;
    }
    .bg-danger {
        background-color: #dc3545 !important;
    }
    .bg-opacity-10 {
        opacity: 0.1;
    }
    .text-primary {
        color: var(--primary-blue) !important;
    }
    .text-success {
        color: #388e3c !important;
    }
    .text-warning {
        color: #ffc107 !important;
    }
    .text-info {
        color: #17a2b8 !important;
    }
    .text-danger {
        color: #dc3545 !important;
    }
    .text-blue {
        color: var(--primary-blue) !important;
    }
    .text-muted {
        color: var(--text-light) !important;
    }
    @media (max-width: 767.98px) {
        .fk-card-header {
            font-size: 14px;
        }
        .stat-card h3 {
            font-size: 20px !important;
        }
        .stat-card p {
            font-size: 12px !important;
        }
        .stat-card .rounded-circle {
            width: 40px !important;
            height: 40px !important;
        }
        .stat-card .rounded-circle i {
            font-size: 18px !important;
        }
        .table {
            font-size: 13px;
        }
        .table th, .table td {
            padding: 8px 10px;
            font-size: 12px;
        }
        .badge {
            font-size: 11px !important;
            padding: 3px 10px !important;
        }
        .btn {
            font-size: 12px !important;
            padding: 4px 10px !important;
        }
    }
    @media (max-width: 575.98px) {
        .fk-card-header {
            font-size: 13px;
            padding-bottom: 8px;
        }
        .stat-card h3 {
            font-size: 18px !important;
        }
        .stat-card p {
            font-size: 11px !important;
        }
        .stat-card .rounded-circle {
            width: 36px !important;
            height: 36px !important;
        }
        .stat-card .rounded-circle i {
            font-size: 16px !important;
        }
        .table {
            font-size: 12px;
        }
        .table th, .table td {
            padding: 6px 8px;
            font-size: 11px;
        }
        .badge {
            font-size: 10px !important;
            padding: 2px 8px !important;
        }
        .btn {
            font-size: 11px !important;
            padding: 3px 8px !important;
        }
        .row.g-3 {
            --bs-gutter-y: 0.5rem;
        }
        .row.g-3 > [class*="col-"] {
            padding-right: 6px;
            padding-left: 6px;
        }
        .quick-stats .d-flex {
            font-size: 13px !important;
        }
        .quick-stats .badge {
            font-size: 11px !important;
            padding: 2px 8px !important;
        }
        .border-left-danger .row.g-2 .col-md-3 {
            width: 50%;
        }
        .border-left-danger .row.g-2 .col-md-3 .border {
            padding: 6px !important;
        }
        .border-left-danger .row.g-2 .col-md-3 p {
            font-size: 11px !important;
        }
    }
</style>

<!-- ============================================================
   জাভাস্ক্রিপ্ট - চার্ট
   ============================================================ -->
{% block extra_js %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // ============================================================
    // সেলস চার্ট
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('salesChart').getContext('2d');
        
        // চার্ট ডেটা
        const chartData = {
            labels: {{ chart_labels|safe }},
            datasets: [{
                label: 'Daily Sales (₹)',
                data: {{ chart_data|safe }},
                backgroundColor: 'rgba(40, 116, 240, 0.08)',
                borderColor: '#2874f0',
                borderWidth: 3,
                pointBackgroundColor: '#2874f0',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 8,
                tension: 0.3,
                fill: true
            }]
        };
        
        // চার্ট কনফিগারেশন
        new Chart(ctx, {
            type: 'line',
            data: chartData,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(0,0,0,0.8)',
                        titleFont: { size: 13, weight: '600' },
                        bodyFont: { size: 13 },
                        padding: 12,
                        cornerRadius: 0,
                        callbacks: {
                            label: function(context) {
                                return '₹' + context.raw.toFixed(2);
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(0,0,0,0.05)',
                            drawBorder: false
                        },
                        ticks: {
                            callback: function(value) {
                                return '₹' + value;
                            },
                            font: { size: 12 }
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            font: { size: 12 }
                        }
                    }
                },
                interaction: {
                    intersect: false,
                    mode: 'index'
                }
            }
        });
    });
    
    // ============================================================
    // অটো রিফ্রেশ (প্রতি ৫ মিনিট)
    // ============================================================
    let refreshInterval = setInterval(function() {
        if (document.visibilityState === 'visible') {
            location.reload();
        }
    }, 300000); // 5 minutes
    
    // পেজ আনলোড হলে ইন্টারভাল ক্লিয়ার করুন
    window.addEventListener('beforeunload', function() {
        clearInterval(refreshInterval);
    });
</script>
{% endblock %}
{% endblock %}