<!-- ============================================================
   জাভাস্ক্রিপ্ট
   ============================================================ -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        
        // ============================================================
        // লোডিং স্কেলটন হাইড করে প্রোডাক্ট দেখানো
        // ============================================================
        function showProducts(sectionId, gridId) {
            const loadingEl = document.getElementById(sectionId);
            const gridEl = document.getElementById(gridId);
            
            if (loadingEl && gridEl) {
                setTimeout(() => {
                    loadingEl.style.transition = 'opacity 0.5s ease';
                    loadingEl.style.opacity = '0';
                    setTimeout(() => {
                        loadingEl.style.display = 'none';
                        gridEl.style.display = 'block';
                        gridEl.style.animation = 'fadeInUp 0.5s ease forwards';
                    }, 500);
                }, 1200);
            }
        }
        
        // For You
        showProducts('loading-for-you', 'products-for-you-grid');
        
        // প্রতিটি ক্যাটাগরি
        {% for category in categories %}
        showProducts('loading-{{ category.slug }}', 'products-{{ category.slug }}-grid');
        {% endfor %}
        
        // ============================================================
        // ট্যাব ক্লিক
        // ============================================================
        const tabs = document.querySelectorAll('.fk-tab-item');
        const categorySliders = document.querySelectorAll('.category-slider');
        const productSections = document.querySelectorAll('.category-products');
        
        function showCategory(categorySlug) {
            // স্লাইডার হাইড/শো
            categorySliders.forEach(slider => {
                slider.style.display = 'none';
                slider.classList.remove('active-slider');
            });
            const targetSlider = document.querySelector(`.category-slider[data-category="${categorySlug}"]`);
            if (targetSlider) {
                targetSlider.style.display = 'block';
                targetSlider.classList.add('active-slider');
                const carousel = targetSlider.querySelector('.carousel');
                if (carousel) {
                    const bsCarousel = bootstrap.Carousel.getInstance(carousel);
                    if (bsCarousel) {
                        bsCarousel.to(0);
                    }
                }
            }
            
            // প্রোডাক্ট হাইড/শো
            productSections.forEach(section => {
                section.style.display = 'none';
                section.classList.remove('active-products');
                section.style.animation = 'none';
            });
            const targetProduct = document.querySelector(`.category-products[data-category="${categorySlug}"]`);
            if (targetProduct) {
                targetProduct.style.display = 'block';
                targetProduct.classList.add('active-products');
                targetProduct.style.animation = 'fadeInUp 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards';
            }
            
            // স্ক্রল
            const headerOffset = 130;
            const targetElement = targetSlider || targetProduct;
            if (targetElement) {
                const elementPosition = targetElement.getBoundingClientRect().top;
                const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
                window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
            }
        }
        
        tabs.forEach(tab => {
            tab.addEventListener('click', function(e) {
                e.preventDefault();
                tabs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                
                const category = this.dataset.category;
                if (category) {
                    showCategory(category);
                }
            });
        });
        
        // ============================================================
        // লোকেশন মডাল
        // ============================================================
        const locationWrapper = document.querySelector('.location-wrapper');
        const locationModal = document.getElementById('locationModal');
        const locationForm = document.getElementById('locationForm');
        
        if (locationWrapper) {
            locationWrapper.addEventListener('click', function() {
                locationModal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            });
        }
        
        window.closeLocationModal = function() {
            locationModal.style.display = 'none';
            document.body.style.overflow = '';
        };
        
        locationModal.addEventListener('click', function(e) {
            if (e.target === this) {
                closeLocationModal();
            }
        });
        
        if (locationForm) {
            locationForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const city = document.getElementById('locationCity').value.trim();
                const area = document.getElementById('locationArea').value.trim();
                
                if (!city) {
                    showToast('Please enter your city', 'error');
                    return;
                }
                
                const submitBtn = this.querySelector('button[type="submit"]');
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Saving...';
                submitBtn.disabled = true;
                
                fetch('/save-location/', {
                    method: 'POST',
                    headers: {
                        'X-CSRFToken': '{{ csrf_token }}',
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ city: city, area: area })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('✅ Location saved successfully!', 'success');
                        const locationText = document.querySelector('.location-text');
                        if (locationText) {
                            locationText.textContent = data.city + (data.area ? ', ' + data.area : '');
                        }
                        closeLocationModal();
                    } else {
                        showToast(data.message || '❌ Failed to save location', 'error');
                    }
                })
                .catch(() => {
                    showToast('❌ Something went wrong', 'error');
                })
                .finally(() => {
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                });
            });
        }
        
        // ============================================================
        // স্ক্রল ইফেক্ট
        // ============================================================
        const header = document.querySelector('.fk-sticky-header');
        let lastScrollY = window.scrollY;
        let ticking = false;
        
        window.addEventListener('scroll', function() {
            if (!ticking) {
                window.requestAnimationFrame(function() {
                    const currentScrollY = window.scrollY;
                    
                    if (currentScrollY > 50) {
                        header.classList.add('sticky-scrolled');
                    } else {
                        header.classList.remove('sticky-scrolled');
                    }
                    
                    if (currentScrollY > 120 && currentScrollY > lastScrollY) {
                        header.style.transform = 'translateY(-100%)';
                    } else if (currentScrollY < lastScrollY || currentScrollY < 120) {
                        header.style.transform = 'translateY(0)';
                    }
                    
                    lastScrollY = currentScrollY;
                    ticking = false;
                });
                ticking = true;
            }
        });
        
        // ============================================================
        // স্লাইডার অটো প্লে পজ
        // ============================================================
        document.querySelectorAll('.carousel').forEach(carousel => {
            carousel.addEventListener('mouseenter', function() {
                const bsCarousel = bootstrap.Carousel.getInstance(this);
                if (bsCarousel) {
                    bsCarousel.pause();
                }
            });
            carousel.addEventListener('mouseleave', function() {
                const bsCarousel = bootstrap.Carousel.getInstance(this);
                if (bsCarousel) {
                    bsCarousel.cycle();
                }
            });
        });
        
        // ============================================================
        // এড টু কার্ট
        // ============================================================
        document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const form = this.closest('form');
                const originalText = this.innerHTML;
                
                this.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>';
                this.disabled = true;
                this.style.transform = 'scale(0.92)';
                
                fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'X-CSRFToken': '{{ csrf_token }}',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: new FormData(form)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('✅ Added to cart!', 'success');
                        updateCartCount(data.cart_count);
                        this.style.transform = 'scale(1.08)';
                        setTimeout(() => this.style.transform = 'scale(1)', 300);
                    } else {
                        showToast(data.message || '❌ Failed to add', 'error');
                    }
                })
                .catch(() => {
                    showToast('❌ Something went wrong', 'error');
                })
                .finally(() => {
                    this.innerHTML = originalText;
                    this.disabled = false;
                    this.style.transform = 'scale(1)';
                });
            });
        });
        
        // ============================================================
        // টোস্ট
        // ============================================================
        window.showToast = function(message, type = 'success') {
            const toast = document.createElement('div');
            const bgColor = type === 'success' ? '#388e3c' : type === 'error' ? '#d32f2f' : '#2874f0';
            toast.style.cssText = `
                position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) scale(0.8);
                padding: 14px 28px; border-radius: 12px; color: #fff; font-weight: 600;
                z-index: 9999; font-size: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.18);
                background: ${bgColor};
                max-width: 90%; text-align: center;
                font-family: 'Inter', sans-serif;
                opacity: 0;
                transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            `;
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '1';
                toast.style.transform = 'translateX(-50%) scale(1)';
            }, 10);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(-50%) scale(0.8)';
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        };
        
        // ============================================================
        // কার্ট কাউন্ট
        // ============================================================
        window.updateCartCount = function(count) {
            document.querySelectorAll('.nav-badge').forEach(el => {
                if (el.closest('a[href*="cart"]')) {
                    if (count > 0) {
                        el.textContent = count;
                        el.style.display = 'inline-block';
                    } else {
                        el.style.display = 'none';
                    }
                }
            });
        };
    });
    
    // ============================================================
    // অটোমেটিক লোকেশন ডিটেক্ট
    // ============================================================
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function(position) {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;
                
                fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=10&accept-language=bn`)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.address) {
                            const city = data.address.city || data.address.town || data.address.village || data.address.county || '';
                            const area = data.address.suburb || data.address.neighbourhood || data.address.road || '';
                            const state = data.address.state || '';
                            
                            if (city) {
                                const locationText = document.getElementById('auto-location-text');
                                if (locationText) {
                                    locationText.textContent = city + (area ? ', ' + area : '');
                                }
                                
                                {% if user.is_authenticated %}
                                fetch('/update-location/', {
                                    method: 'POST',
                                    headers: {
                                        'X-CSRFToken': '{{ csrf_token }}',
                                        'Content-Type': 'application/json',
                                    },
                                    body: JSON.stringify({
                                        city: city,
                                        area: area || state || '',
                                        latitude: lat,
                                        longitude: lng
                                    })
                                })
                                .then(response => response.json())
                                .then(data => {
                                    if (data.success) {
                                        console.log('✅ Location auto-saved:', data.city);
                                    }
                                })
                                .catch(err => console.log('⚠️ Location save error:', err));
                                {% endif %}
                            }
                        }
                    })
                    .catch(err => console.log('⚠️ Reverse geocoding error:', err));
            },
            function(error) {
                console.log('⚠️ Geolocation error:', error.message);
                fetch('https://ipapi.co/json/')
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.city) {
                            const locationText = document.getElementById('auto-location-text');
                            if (locationText) {
                                locationText.textContent = data.city + (data.region ? ', ' + data.region : '');
                            }
                            {% if user.is_authenticated %}
                            fetch('/update-location/', {
                                method: 'POST',
                                headers: {
                                    'X-CSRFToken': '{{ csrf_token }}',
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({
                                    city: data.city || '',
                                    area: data.region || '',
                                    latitude: data.latitude || null,
                                    longitude: data.longitude || null
                                })
                            })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    console.log('✅ Location auto-saved from IP:', data.city);
                                }
                            })
                            .catch(err => console.log('⚠️ IP location save error:', err));
                            {% endif %}
                        }
                    })
                    .catch(err => console.log('⚠️ IP location error:', err));
            },
            {
                enableHighAccuracy: true,
                timeout: 10000,
                maximumAge: 0
            }
        );
    } else {
        fetch('https://ipapi.co/json/')
            .then(response => response.json())
            .then(data => {
                if (data && data.city) {
                    const locationText = document.getElementById('auto-location-text');
                    if (locationText) {
                        locationText.textContent = data.city + (data.region ? ', ' + data.region : '');
                    }
                }
            })
            .catch(err => console.log('⚠️ IP location error:', err));
    }
</script>

{% endblock %}